{
  "permissions": {
    "allow": [
      "Bash(git fetch)",
      "Bash(git fetch *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.pm/hooks/load-assignment.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.pm/hooks/load-handoff.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.pm/hooks/context-watch.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.pm/hooks/report-on-stop.sh" }
        ]
      }
    ]
  }
}
